# =============================================================================
# RecupDZ — Environment Variables
# Copy to .env and customize
# =============================================================================

# Django
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5175

# Database (leave DB_HOST empty for SQLite, set for PostgreSQL)
DB_NAME=recupdz_db
DB_USER=recupdz_user
DB_PASSWORD=recupdz_password
DB_HOST=
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=hermes3
OLLAMA_TIMEOUT=30

# AI Module
MAX_TOOL_ROUNDS=5
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60
CACHE_BACKEND=memory
CACHE_TTL=300
SANITIZE_INPUT=true
AUDIT_ENABLED=true
METRICS_ENABLED=true
TRACING_ENABLED=true

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# Security (production only)
SECURE_SSL_REDIRECT=false

# Ports
BACKEND_PORT=8002
FRONTEND_PORT=5175
REDIS_PORT=6379
OLLAMA_PORT=11434
